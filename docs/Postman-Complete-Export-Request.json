{
  "info": {
    "name": "Export Indicateurs - Requête Complète",
    "description": "Collection complète pour tester tous les exports d'indicateurs avec toutes les options possibles",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🚀 EXPORT COMPLET - Toutes Options",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Générer un nom de fichier unique avec timestamp",
              "const timestamp = new Date().toISOString().slice(0, 19).replace(/[-:]/g, '').replace('T', '_');",
              "pm.collectionVariables.set('timestamp', timestamp);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"columnsToExport\": [\n    \"ID\",\n    \"INDICATEUR\", \n    \"DESCRIPTION\",\n    \"CATEGORIE\",\n    \"SOURCE\",\n    \"UNITE\",\n    \"TYPE_GRAPHE\",\n    \"TYPE_TB\",\n    \"ACTIF\",\n    \"HAS_DATA\",\n    \"ABREVIATION\",\n    \"REGLE_CALCUL\",\n    \"DOMAINES\",\n    \"SOUS_DOMAINES\",\n    \"ESPACES\"\n  ],\n  \"groupBy\": \"BY_DOMAINE\",\n  \"fileName\": \"export_complet_{{timestamp}}\",\n  \"activeOnly\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/indicateurs/audit/export/custom",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "indicateurs",
            "audit",
            "export",
            "custom"
          ]
        },
        "description": "Export complet avec toutes les colonnes disponibles, groupé par domaine"
      },
      "response": []
    },
