  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Vérifier que le token est défini",
          "if (!pm.collectionVariables.get('token') || pm.collectionVariables.get('token') === 'YOUR_JWT_TOKEN_HERE') {",
          "    console.warn('⚠️  N\\'oubliez pas de définir votre token JWT dans les variables de collection !');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Tests automatiques",
          "pm.test('Status code should be 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('Response should be an Excel file', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('spreadsheet');",
          "});",
          "",
          "pm.test('Response should have Content-Disposition header', function () {",
          "    pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment');",
          "});",
          "",
          "// Log des informations utiles",
          "console.log('📁 Nom du fichier:', pm.response.headers.get('Content-Disposition'));",
          "console.log('📊 Taille du fichier:', pm.response.headers.get('Content-Length'), 'bytes');"
        ]
      }
    }
  ]
